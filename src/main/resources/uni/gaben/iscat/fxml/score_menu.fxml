<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  REWORK NOTES:
  • Removed maxWidth="-Infinity" maxHeight="-Infinity" from root BorderPane.
    In JavaFX FXML those parse to USE_COMPUTED_SIZE, preventing the node from
    stretching to fill its StackPane parent — the window was 1280x720 but the
    BorderPane locked itself to its preferred/computed size.
  • Removed all inline <Font> declarations and textFill attributes; replaced
    with CSS styleClass hooks so ThemeManager drives the colors.
  • Removed absolute layoutX/layoutY from labels inside VBox (they have no
    effect inside a managed flow layout and can cause overlap on resize).
  • Score stat labels use fx:id so ScoreMenuController can set their text.
-->
<StackPane stylesheets="@../styles/scenes/score-menu.css"
           xmlns="http://javafx.com/javafx/"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="uni.gaben.iscat.iscat_screens.scores.ScoreMenuController">

    <!-- No maxWidth/maxHeight — fills the StackPane (and therefore the window) -->
    <BorderPane fx:id="rootPane" styleClass="menu-background">

        <top>
            <VBox alignment="CENTER" spacing="8.0">
                <padding>
                    <Insets top="40.0" bottom="10.0"/>
                </padding>
                <Label styleClass="menu-title" text="SCORE"/>
            </VBox>
        </top>

        <center>
            <HBox alignment="CENTER">
                <VBox alignment="CENTER" spacing="18.0"
                      styleClass="glowing-border, main-card">
                    <padding>
                        <Insets bottom="28.0" left="40.0" right="40.0" top="28.0"/>
                    </padding>

                    <Label styleClass="card-header" text="IL TUO SCORE:"/>

                    <VBox spacing="10.0">
                        <Label fx:id="skinNameLabel"
                               styleClass="score-stat"
                               text="Best Score: 1000"/>
                        <Label fx:id="skinNameLabel1"
                               styleClass="score-stat"
                               text="Nemici sconfitti: 69"/>
                        <Label fx:id="skinNameLabel11"
                               styleClass="score-stat"
                               text="Miglior tempo: 5min"/>
                        <Label fx:id="skinNameLabel12"
                               styleClass="score-stat"
                               text="Danni subiti: 6799"/>
                        <Label fx:id="skinNameLabel111"
                               styleClass="score-stat"
                               text="Danni causati: 9999"/>
                    </VBox>

                    <Region prefHeight="10.0"/>

                    <Button maxWidth="Infinity"
                            onAction="#handleBack"
                            styleClass="menu-button, play-button"
                            text="ESCI DAL MENU"/>
                </VBox>
            </HBox>
        </center>

        <bottom>
            <Region minHeight="50.0" prefHeight="50.0"/>
        </bottom>

    </BorderPane>
</StackPane>
