<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/scenes/main-menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.screens.main_menu.MenuController">

    <BorderPane fx:id="paneMaster" styleClass="menu-background">
        <top>
            <Region minHeight="56.0" prefHeight="56.0" />
        </top>

        <center>
            <HBox alignment="CENTER" spacing="32.0">
                <padding>
                    <Insets bottom="16.0" left="32.0" right="32.0" top="16.0" />
                </padding>

                <VBox alignment="CENTER" maxWidth="300.0" minWidth="200.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" rotate="-2.5" spacing="10.0" styleClass="glowing-border, secondary-card">
                        <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                        <Label styleClass="card-header" text="CUSTOMIZE!" />
                        <Button fx:id="skinButton" contentDisplay="TOP" onAction="#openSkinMenu" styleClass="menu-button" text="CHANGE SKIN" />
                        <Button fx:id="bestiaryButton" contentDisplay="TOP" onAction="#openBestiaryMenu" styleClass="menu-button" text="BESTIARIO" />
                    </VBox>
                </VBox>

                <VBox alignment="CENTER" maxWidth="340.0" minWidth="240.0" spacing="16.0" HBox.hgrow="ALWAYS">
                    <Label text="ISCAT">
                  <styleClass>
                     <String fx:value="menu-title" />
                     <String fx:value="display-large" />
                  </styleClass></Label>
                    <VBox alignment="CENTER" rotate="-1.0" spacing="10.0" styleClass="glowing-border, main-card">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <Button fx:id="playButton" contentDisplay="TOP" onAction="#playGame" styleClass="menu-button, play-button" text="PLAY" />
                        <Button fx:id="optionsButton" contentDisplay="TOP" onAction="#openOptionsMenu" styleClass="menu-button" text="OPTIONS" />
                        <Button fx:id="quitButton" contentDisplay="TOP" onAction="#quit" styleClass="menu-button, danger-button-weak" text="QUIT" />
                    </VBox>
                </VBox>

                <VBox alignment="CENTER" maxWidth="300.0" minWidth="200.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" rotate="2.5" spacing="10.0" styleClass="glowing-border, secondary-card">
                        <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                        <Label styleClass="card-header" text="PROFILE" />
                        <Button fx:id="scoreButton" contentDisplay="BOTTOM" onAction="#openScoreMenu" styleClass="menu-button" text="VIEW SCORE" />
                        <Button fx:id="logoutButton" contentDisplay="TOP" onAction="#logout" styleClass="menu-button, danger-button-weak" text="LOG OUT" />
                    </VBox>
                </VBox>
            </HBox>
        </center>

        <bottom>
            <Region minHeight="56.0" prefHeight="56.0" />
        </bottom>
    </BorderPane>
</StackPane>
