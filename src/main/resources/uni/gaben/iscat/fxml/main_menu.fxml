<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/main-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.MainMenuController">

    <BorderPane fx:id="paneMaster" styleClass="menu-background">
        <top>
            <Region minHeight="40.0" prefHeight="40.0" />
        </top>

        <center>
            <VBox alignment="CENTER" spacing="24.0">
                <padding>
                    <Insets bottom="32.0" left="64.0" right="64.0" top="16.0" />
                </padding>

                <Label text="ISCAT" rotate="0.5">
                    <styleClass>
                        <String fx:value="menu-title" />
                        <String fx:value="display-large" />
                    </styleClass>
                </Label>

                <Region minHeight="8.0" prefHeight="8.0" />

                <VBox alignment="CENTER" maxWidth="380.0" minWidth="280.0" spacing="14.0" rotate="-0.5" styleClass="glowing-border, main-card">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>

                    <Button fx:id="playButton" maxWidth="Infinity" prefHeight="54.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" contentDisplay="RIGHT" onAction="#playGame" styleClass="menu-button, play-button" text="PLAY" />
                    <Button fx:id="bestiaryButton" maxWidth="Infinity" prefHeight="54.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" contentDisplay="RIGHT" onAction="#openBestiaryMenu" styleClass="menu-button" text="BESTIARIO" />
                    <Button fx:id="skinButton" maxWidth="Infinity" prefHeight="54.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" contentDisplay="RIGHT" onAction="#openSkinMenu" styleClass="menu-button" text="CHANGE SKIN" />

                    <Button fx:id="scoreButton" maxWidth="Infinity" prefHeight="54.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" contentDisplay="RIGHT" onAction="#openScoreMenu" styleClass="menu-button" text="VIEW SCORE" />
                    <Button fx:id="leaderboardButton" maxWidth="Infinity" prefHeight="54.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" contentDisplay="RIGHT" onAction="#openLeaderboardMenu" styleClass="menu-button" text="LEADERBOARD" />
                    <Button fx:id="optionsButton" maxWidth="Infinity" prefHeight="54.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" contentDisplay="RIGHT" onAction="#openOptionsMenu" styleClass="menu-button" text="OPTIONS" />

                    <Region minHeight="8.0" prefHeight="8.0" />

                    <Button fx:id="logoutButton" maxWidth="Infinity" prefHeight="50.0" style="-fx-font-size: 15px;" contentDisplay="RIGHT" onAction="#logout" styleClass="menu-button, danger-button-weak" text="LOG OUT" />
                    <Button fx:id="quitButton" maxWidth="Infinity" prefHeight="50.0" style="-fx-font-size: 15px;" contentDisplay="RIGHT" onAction="#quit" styleClass="menu-button, danger-button-weak" text="QUIT" />
                </VBox>

            </VBox>
        </center>

        <bottom>
            <Region minHeight="56.0" prefHeight="56.0" />
        </bottom>
    </BorderPane>
</StackPane>