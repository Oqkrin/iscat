<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<StackPane fx:id="paneMaster" minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/main-menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.MainMenuController">
   <VBox>
      <children>
            <Region minHeight="56.0" prefHeight="56.0" />
         <HBox VBox.vgrow="ALWAYS">
            <children>
               <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                  <children>
                     <Region VBox.vgrow="ALWAYS" />
      
                                                  <Button fx:id="scoreButton" contentDisplay="TOP" onAction="#openScoreMenu" rotate="4.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" styleClass="menu-button" text="VIEW SCORE">
                        <padding>
                           <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                        </padding>
                     </Button>
                     <Region VBox.vgrow="ALWAYS" />
                          <Button fx:id="leaderboardButton" contentDisplay="TOP" onAction="#openLeaderboardMenu" rotate="-3.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" styleClass="menu-button" text="LEADERBOARD">
                        <padding>
                           <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                        </padding>
                     </Button>
                     <Region VBox.vgrow="ALWAYS" />
                  </children>
               </VBox>
                  <VBox alignment="CENTER" spacing="16.0" HBox.hgrow="ALWAYS">
                      <padding>
                          <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                      </padding>
                  <Region VBox.vgrow="ALWAYS" />
                  <Region VBox.vgrow="ALWAYS" />
      
                                              <Label rotate="0.5" text="ISCAT">
                          <styleClass>
                              <String fx:value="menu-title" />
                              <String fx:value="display-large" />
                          </styleClass>
                      </Label>
      
                                              <Region VBox.vgrow="ALWAYS" />
   
                                                  <Button fx:id="playButton" contentDisplay="TOP" onAction="#playGame" style="-fx-font-size: 18px; -fx-font-weight: bold;" styleClass="menu-button, play-button" text="PLAY">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                  </Button>
                  <Region VBox.vgrow="ALWAYS" />
                  <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
                     <children>
         
                                                        <Button fx:id="logoutButton" onAction="#logout" rotate="4.0" style="-fx-font-size: 12px;" styleClass="menu-button, danger-button-weak" text="LOG-OUT" translateX="-16.0">
                           <padding>
                              <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                           </padding>
                        </Button>
                             <Button fx:id="optionsButton" contentDisplay="TOP" onAction="#openOptionsMenu" style="-fx-font-size: 15px; -fx-font-weight: bold;" styleClass="menu-button" text="OPTIONS" translateY="16.0">
                           <padding>
                              <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                           </padding>
                        </Button>
                             <Button fx:id="quitButton" cancelButton="true" contentDisplay="RIGHT" onAction="#quit" rotate="-4.0" style="-fx-font-size: 15px;" text="QUIT" translateX="16.0">
                           <padding>
                              <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                           </padding>
                           <styleClass>
                              <String fx:value="menu-button" />
                              <String fx:value="danger-button-strong" />
                           </styleClass>
                        </Button>
                     </children>
                  </HBox>
                  <Region VBox.vgrow="ALWAYS" />
      
                                          </VBox>
               <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                  <children>
                     <Region VBox.vgrow="ALWAYS" />
                          <Button fx:id="bestiaryButton" contentDisplay="TOP" onAction="#openBestiaryMenu" rotate="-3.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" styleClass="menu-button" text="BESTIARIO" VBox.vgrow="ALWAYS">
                        <padding>
                           <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                        </padding>
                     </Button>
                     <Region VBox.vgrow="ALWAYS">
                        <VBox.margin>
                           <Insets />
                        </VBox.margin>
                     </Region>
                          <Button fx:id="skinButton" alignment="CENTER" contentDisplay="TOP" onAction="#openSkinMenu" rotate="4.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" styleClass="menu-button" text="CHANGE SKIN" textAlignment="CENTER" VBox.vgrow="ALWAYS">
                        <padding>
                           <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                        </padding>
                     </Button>
                     <Region VBox.vgrow="ALWAYS" />
                  </children>
               </VBox>
            </children>
         </HBox>
            <Region minHeight="56.0" prefHeight="56.0" />
      </children>
   </VBox>
</StackPane>
