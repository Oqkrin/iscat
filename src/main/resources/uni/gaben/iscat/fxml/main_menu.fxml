<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/scenes/main-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.iscat_screens.main_menu.MenuController">

    <BorderPane fx:id="paneMaster" styleClass="menu-background">
        <top>
            <Region minHeight="56.0" prefHeight="56.0"/>
        </top>

        <center>
            <HBox alignment="CENTER" spacing="32.0">
                <padding>
                    <Insets bottom="16.0" left="32.0" right="32.0" top="16.0"/>
                </padding>

                <VBox alignment="CENTER" maxWidth="300.0" minWidth="200.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" rotate="-2.5" spacing="10.0" styleClass="glowing-border, secondary-card">
                        <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0"/></padding>
                        <Label styleClass="card-header" text="CUSTOMIZE!"/>
                        <Button fx:id="skinButton" maxWidth="Infinity" onAction="#openSkinMenu" styleClass="menu-button" text="CHANGE SKIN"/>
                        <Button fx:id="bestiaryButton" maxWidth="Infinity" onAction="#openBestiaryMenu" styleClass="menu-button" text="BESTIARIO"/>
                    </VBox>
                </VBox>

                <VBox alignment="CENTER" maxWidth="340.0" minWidth="240.0" spacing="16.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="menu-title" text="ISCAT"/>
                    <VBox alignment="CENTER" rotate="-1.0" spacing="10.0" styleClass="glowing-border, main-card">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>
                        <Button fx:id="playButton" maxWidth="Infinity" onAction="#playGame" styleClass="menu-button, play-button" text="PLAY"/>
                        <Button fx:id="optionsButton" maxWidth="Infinity" onAction="#openOptionsMenu" styleClass="menu-button" text="OPTIONS"/>
                        <Button fx:id="quitButton" maxWidth="Infinity" onAction="#quit" styleClass="menu-button, danger-button-weak" text="QUIT"/>
                    </VBox>
                </VBox>

                <VBox alignment="CENTER" maxWidth="300.0" minWidth="200.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" rotate="2.5" spacing="10.0" styleClass="glowing-border, secondary-card">
                        <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0"/></padding>
                        <Label styleClass="card-header" text="PROFILE"/>
                        <Button fx:id="scoreButton" maxWidth="Infinity" onAction="#openScoreMenu" styleClass="menu-button" text="VIEW SCORE"/>
                        <Button fx:id="logoutButton" maxWidth="Infinity" onAction="#logout" styleClass="menu-button, danger-button-weak" text="LOG OUT"/>
                    </VBox>
                </VBox>
            </HBox>
        </center>

        <bottom>
            <Region minHeight="56.0" prefHeight="56.0"/>
        </bottom>
    </BorderPane>
</StackPane>