<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/game.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.game.GamePauseMenuController">

    <VBox alignment="CENTER" styleClass="game-pause-overlay" StackPane.alignment="CENTER">
        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
        </padding>
      <Region minHeight="56.0" prefHeight="56.0" VBox.vgrow="NEVER" />

        <HBox alignment="CENTER" spacing="16.0" VBox.vgrow="ALWAYS">
         <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
            <children>
                   <fx:include fx:id="subDisplay" rotate="-3.0" source="components/settings/DisplaySettings.fxml" HBox.hgrow="ALWAYS" VBox.vgrow="NEVER" />
            </children>
            <padding>
               <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>
         </VBox>

            <VBox alignment="CENTER" spacing="16.0" HBox.hgrow="ALWAYS">
                 <Label styleClass="pause-title" text="PAUSE">
                     <font>
                         <Font name="System Bold" size="48.0" />
                     </font>
                 </Label>
                 <Button fx:id="resumeBtn" alignment="CENTER" onAction="#handleResume" styleClass="pulsante-menu, primario" text="RESUME GAME">
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
               </padding></Button>
                 <Button fx:id="settingsBtn" alignment="CENTER" onAction="#openSettingsMenu" styleClass="pulsante-menu" text="OPTIONS">
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
               </padding></Button>
                 <Button fx:id="menuBtn" alignment="CENTER" onAction="#handleQuitToMenu" styleClass="pulsante-menu" text="QUIT TO MENU">
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
               </padding></Button>
                 <Button fx:id="quitBtn" alignment="CENTER" onAction="#handleQuitGame" styleClass="pulsante-menu, pericolo" text="QUIT GAME">
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
               </padding></Button>
            <padding>
               <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>

            </VBox>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
                <fx:include fx:id="subAudio" rotate="2.0" source="components/settings/AudioSettings.fxml" />
            <padding>
               <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
            </padding>
            </VBox>
         <VBox.margin>
            <Insets />
         </VBox.margin>
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding>

        </HBox>
      <Region minHeight="56.0" prefHeight="56.0" VBox.vgrow="NEVER" />
    </VBox>

    <fx:include fx:id="confirmOverlay" source="components/ConfirmationOverlay.fxml" />
</StackPane>
