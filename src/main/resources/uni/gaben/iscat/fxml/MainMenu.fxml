<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="paneMaster" minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/main-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.menus.MainMenuController">
   <VBox>
      <children>
         <Region minHeight="56.0" prefHeight="56.0" />
         <HBox VBox.vgrow="ALWAYS">
            <children>
               <Region minHeight="56.0" prefHeight="56.0" HBox.hgrow="ALWAYS" />

               <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                  <children>
                     <Region VBox.vgrow="ALWAYS" />
                     <Region VBox.vgrow="ALWAYS" />

                     <Button fx:id="leaderboardButton" contentDisplay="TOP" onAction="#openLeaderboardMenu" rotate="-4.0" text="LEADERBOARD">
                        <padding>
                           <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <styleClass>
                           <String fx:value="menu-button" />
                           <String fx:value="title-large" />
                        </styleClass>
                     </Button>

                     <Region VBox.vgrow="ALWAYS" />

                     <Button fx:id="scoreButton" contentDisplay="TOP" onAction="#openScoreMenu" rotate="4.0" text="VIEW SCORE">
                        <padding>
                           <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <styleClass>
                           <String fx:value="menu-button" />
                           <String fx:value="title-large" />
                        </styleClass>
                     </Button>
                     <Region VBox.vgrow="ALWAYS" />
                  </children>
               </VBox>

               <VBox alignment="CENTER" spacing="16.0" HBox.hgrow="ALWAYS">
                  <padding>
                     <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                  </padding>
                  <Region VBox.vgrow="ALWAYS" />
                  <Region VBox.vgrow="ALWAYS" />

                  <Label rotate="0.5" text="ISCAT">
                     <styleClass>
                        <String fx:value="menu-title" />
                        <String fx:value="display-large" />
                     </styleClass>
                  </Label>

                  <Region VBox.vgrow="ALWAYS" />

                  <Button fx:id="playButton" alignment="CENTER" contentDisplay="LEFT" onAction="#playGame" prefWidth="240.0" maxWidth="240.0" text="PLAY" textAlignment="CENTER">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                     <styleClass>
                        <String fx:value="menu-button" />
                        <String fx:value="play-button" />
                        <String fx:value="title-large" />
                     </styleClass>
                  </Button>

                  <Button fx:id="tutorialButton" alignment="CENTER" contentDisplay="LEFT" onAction="#openTutorialMenu" prefWidth="240.0" maxWidth="240.0" rotate="-1.5" text="TUTORIAL" textAlignment="CENTER">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                     <styleClass>
                        <String fx:value="menu-button" />
                        <String fx:value="title-large" />
                     </styleClass>
                  </Button>

                  <Region VBox.vgrow="ALWAYS" />

                  <Button fx:id="creditsButton" contentDisplay="LEFT" graphicTextGap="16.0" onAction="#openCreditsMenu" prefWidth="240.0" maxWidth="240.0" rotate="-3.0" text="CREDITS">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                     <styleClass>
                        <String fx:value="menu-button" />
                        <String fx:value="title-large" />
                     </styleClass>
                  </Button>

                  <Button fx:id="settingsButton" contentDisplay="LEFT" onAction="#openSettingsMenu" prefWidth="240.0" maxWidth="240.0" rotate="3.0" text="SETTINGS">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                     <styleClass>
                        <String fx:value="menu-button" />
                        <String fx:value="title-large" />
                     </styleClass>
                  </Button>

                  <Button fx:id="logoutButton" contentDisplay="LEFT" onAction="#logout" prefWidth="240.0" maxWidth="240.0" rotate="-4.0" text="LOG-OUT">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                     <styleClass>
                        <String fx:value="menu-button" />
                        <String fx:value="danger-button-weak" />
                        <String fx:value="title-large" />
                     </styleClass>
                  </Button>

                  <Button fx:id="quitButton" contentDisplay="LEFT" cancelButton="true" onAction="#quit" prefWidth="240.0" maxWidth="240.0" rotate="4.0" text="QUIT">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                     <styleClass>
                        <String fx:value="menu-button" />
                        <String fx:value="danger-button-strong" />
                        <String fx:value="title-large" />
                     </styleClass>
                  </Button>
                  <Region VBox.vgrow="ALWAYS" />

               </VBox>

               <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                  <children>
                     <Region VBox.vgrow="ALWAYS" />
                     <Region VBox.vgrow="ALWAYS" />
                     <Button fx:id="bestiaryButton" contentDisplay="TOP" onAction="#openBestiaryMenu" rotate="-3.0" text="BESTIARIO" VBox.vgrow="ALWAYS">
                        <padding>
                           <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <styleClass>
                           <String fx:value="menu-button" />
                           <String fx:value="title-large" />
                        </styleClass>
                     </Button>
                     <Region VBox.vgrow="ALWAYS" />
                     <Region VBox.vgrow="ALWAYS" />
                     <Button fx:id="skinButton" alignment="CENTER" contentDisplay="TOP" onAction="#openSkinMenu" rotate="4.0" text="CHANGE SKIN" textAlignment="CENTER" VBox.vgrow="ALWAYS">
                        <padding>
                           <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <styleClass>
                           <String fx:value="menu-button" />
                           <String fx:value="title-large" />
                        </styleClass>
                     </Button>
                     <Region VBox.vgrow="ALWAYS" />
                  </children>
               </VBox>
               <Region minHeight="56.0" prefHeight="56.0" HBox.hgrow="ALWAYS" />
            </children>
         </HBox>
         <Region minHeight="56.0" prefHeight="56.0" />
      </children>
   </VBox>

   <fx:include fx:id="confirmOverlay" source="components/ConfirmationOverlay.fxml" />
</StackPane>
