<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>



 <VBox alignment="TOP_CENTER" spacing="16.0" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.components.settings.AccountSettingsController">
     <padding>
         <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
     </padding>
   <HBox alignment="CENTER">
      <children>
            <Label styleClass="card-header" text="ACCOUNT" />
      </children>
   </HBox>

     <VBox alignment="CENTER" spacing="16.0">
         <Button onAction="#changeUsername" text="CHANGE USERNAME">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </Button>
         <Button onAction="#changePassword" text="CHANGE PASSWORD">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </Button>
         <Button onAction="#resetAccount" text="RESET ACCOUNT">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </Button>

         <Button onAction="#deleteAccount" styleClass="danger-button" text="DELETE ACCOUNT">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
      </Button>
     </VBox>
   <styleClass>
      <String fx:value="glowing-border" />
      <String fx:value="controls-card" />
   </styleClass>
 </VBox>
