<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<VBox fx:id="theme" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uni.gaben.iscat.controller.components.options.ThemeSettingsController"
      styleClass="glowing-border, controls-card">
    <VBox alignment="CENTER" spacing="16.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <Label styleClass="card-header" text="PREVIEW"/>

        <StackPane fx:id="imageArea" maxHeight="180.0" maxWidth="320.0" minHeight="180.0"
                   styleClass="theme-preview-container" VBox.vgrow="NEVER">
            <ImageView fx:id="themePreview" fitHeight="180" fitWidth="320" preserveRatio="true"/>
            <Button fx:id="pickImageBtn" onAction="#onImagePick" styleClass="ability-button" text="Pick Image"
                    StackPane.alignment="CENTER"/>
        </StackPane>

        <HBox alignment="CENTER" spacing="12.0" styleClass="theme-navigation-row">
            <Button fx:id="prevThemeBtn" onAction="#prevTheme" styleClass="nav-button" text="&lt;"/>
            <Button fx:id="addImageBtn" managed="false" styleClass="ability-button" text="ADD IMAGE" visible="false"/>
            <Button fx:id="nextThemeBtn" onAction="#nextTheme" styleClass="nav-button" text="&gt;"/>
        </HBox>

        <VBox fx:id="hiddenPickers" alignment="CENTER" managed="false" visible="false">
            <ColorPicker fx:id="accentTernary"/>
            <ColorPicker fx:id="bgPrimary"/>
            <ColorPicker fx:id="accentSecondary"/>
            <ColorPicker fx:id="accentPrimary"/>
        </VBox>

        <HBox fx:id="pickerRow1" alignment="CENTER" spacing="8.0" styleClass="color-picker-row"/>
        <HBox fx:id="pickerRow2" alignment="CENTER" spacing="8.0" styleClass="color-picker-row"/>
        <Label styleClass="palette-hint" text="Premi un selettore, poi un colore"/>
        <HBox fx:id="paletteHolder" alignment="CENTER" spacing="6" styleClass="palette-holder" VBox.vgrow="NEVER"/>
    </VBox>

    <VBox alignment="TOP_CENTER" spacing="16.0" VBox.vgrow="SOMETIMES">
        <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
        </padding>

        <VBox alignment="CENTER" spacing="10.0" styleClass="theme-modes-box">
            <HBox alignment="CENTER_LEFT" styleClass="theme-mode-row">
                <Label styleClass="theme-row-label" text="Light Mode"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox fx:id="lightModeCheck" onAction="#toggleThemeMode" text=""/>
            </HBox>

            <HBox alignment="CENTER_LEFT" styleClass="theme-mode-row">
                <Label styleClass="theme-row-label" text="Rainbow Mode"/>
                <Region HBox.hgrow="ALWAYS"/>
                <CheckBox fx:id="rainbowModeCheck" onAction="#toggleRainbowMode" text=""/>
            </HBox>
        </VBox>

        <Region minHeight="4.0" prefHeight="4.0" VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>
