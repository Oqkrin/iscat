<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="theme" alignment="CENTER" spacing="16.0" styleClass="glowing-border, controls-card" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.components.settings.ThemeSettingsController">
   <HBox alignment="CENTER" spacing="16.0">
      <children>
            <Button fx:id="prevThemeBtn" styleClass="nav-button" text="&lt;" />
            <Button fx:id="addImageBtn" managed="false" styleClass="ability-button" text="ADD IMAGE" visible="false" />
            <Button fx:id="nextThemeBtn" styleClass="nav-button" text="&gt;" />
      </children>
   </HBox>
   <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
      <children>
            <StackPane fx:id="imageArea" styleClass="theme-preview-container" VBox.vgrow="ALWAYS">
                <ImageView fx:id="themePreview" preserveRatio="true" />
                <Button fx:id="pickImageBtn" onAction="#onImagePick" styleClass="ability-button" text="Pick Image" StackPane.alignment="CENTER" />
            </StackPane>
      </children>
   </VBox>
   <VBox alignment="CENTER" fillWidth="false" spacing="16.0">
      <children>
         <HBox alignment="CENTER" spacing="4.0">
            <children>
                  <HBox fx:id="pickerRow1" alignment="CENTER" spacing="8.0" styleClass="color-picker-row" HBox.hgrow="NEVER" />
                  <HBox fx:id="pickerRow2" alignment="CENTER" spacing="8.0" styleClass="color-picker-row" HBox.hgrow="NEVER" />
            </children>
            <padding>
               <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
            </padding>
         </HBox>
         <HBox alignment="CENTER" spacing="32.0">
            <children>
                 <CheckBox fx:id="rainbowModeCheck" nodeOrientation="LEFT_TO_RIGHT" onAction="#toggleRainbowMode" text="Rainbow Mode" />
                 <CheckBox fx:id="lightModeCheck" alignment="CENTER_RIGHT" nodeOrientation="RIGHT_TO_LEFT" onAction="#toggleThemeMode" text="Light Mode" />
            </children>
         </HBox>
      </children>
   </VBox>

    <!-- Palette hint -->
    <Label fx:id="paletteTip" styleClass="palette-hint" text="PALETTE GENERATA : SELEZIONA COLORE DA MODIFICARE MANUALMENTE!" />

    <!-- Extracted palette circles -->
    <HBox fx:id="paletteHolder" alignment="CENTER" styleClass="palette-holder" VBox.vgrow="NEVER" />

    <!-- Light / Rainbow mode checkboxes -->
    <HBox alignment="CENTER" styleClass="theme-navigation-row" />

    <!-- Hidden real ColorPicker nodes (needed for custom picker widgets) -->
    <VBox fx:id="hiddenPickers" alignment="CENTER" managed="false" visible="false">
        <ColorPicker fx:id="accentTernary" />
        <ColorPicker fx:id="bgPrimary" />
        <ColorPicker fx:id="accentSecondary" />
        <ColorPicker fx:id="accentPrimary" />
    </VBox>

    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>
</VBox>
