<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>



 <VBox alignment="CENTER" fillWidth="false" spacing="16.0" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.components.settings.KeybindsSettingsController">
     <padding>
         <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
     </padding>

     <VBox alignment="CENTER" spacing="4.0">
         <Label styleClass="card-header" text="KEYBINDINGS" />
         <Label styleClass="card-subheader" text="CLICCA UN PULSANTE PER CAMBIARE IL TASTO" />
     </VBox>

     <Region VBox.vgrow="ALWAYS" />

     <VBox alignment="CENTER" spacing="6.0" styleClass="movement-box">
         <padding>
             <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <Label styleClass="movement-header" text="MOVEMENT" />

         <Button fx:id="walkUp" onAction="#changeControl" text="W">
         <padding>
            <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
         </padding>
      </Button>

         <HBox alignment="CENTER" spacing="6.0">
             <Button fx:id="walkLeft" onAction="#changeControl" text="A">
            <padding>
               <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
            </padding>
         </Button>
             <Button fx:id="walkDown" onAction="#changeControl" text="S">
            <padding>
               <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
            </padding>
         </Button>
             <Button fx:id="walkRight" onAction="#changeControl" text="D">
            <padding>
               <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
            </padding>
         </Button>
         </HBox>
     </VBox>

     <Region VBox.vgrow="ALWAYS" />

     <VBox alignment="CENTER" spacing="8.0">

         <HBox alignment="CENTER_LEFT" styleClass="keybind-row">
             <Label text="Attack" />
             <Region HBox.hgrow="ALWAYS" />
             <Button fx:id="attack" onAction="#changeControl" text="MOUSEPRIMARY" />
         </HBox>

         <HBox alignment="CENTER_LEFT" styleClass="keybind-row">
             <Label text="Dash Primario" />
             <Region HBox.hgrow="ALWAYS" />
             <Button fx:id="dash1" onAction="#changeControl" text="Q" />
         </HBox>

         <HBox alignment="CENTER_LEFT" styleClass="keybind-row">
             <Label text="Dash Secondario" />
             <Region HBox.hgrow="ALWAYS" />
             <Button fx:id="dash2" onAction="#changeControl" text="E" />
         </HBox>

         <HBox alignment="CENTER_LEFT" styleClass="keybind-row">
             <Label text="Pause Menu" />
             <Region HBox.hgrow="ALWAYS" />
             <Button fx:id="esc" onAction="#changeControl" text="P" />
         </HBox>

     </VBox>

     <Region VBox.vgrow="ALWAYS" />

     <Button fx:id="resetControlsBtn" onAction="#resetControls" styleClass="reset-button" text="RESTORE DEFAULTS" />
   <styleClass>
      <String fx:value="controls-card" />
      <String fx:value="glowing-border" />
   </styleClass>
 </VBox>
