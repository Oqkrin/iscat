<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/bestiary-menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.menus.BestiaryMenuController">
    <VBox alignment="CENTER" styleClass="menu-background">
        <children>
            <Region minHeight="56.0" prefHeight="56.0" VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="16.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                </padding>

                <VBox alignment="CENTER" rotate="-1.5" spacing="16.0" styleClass="glowing-border, secondary-card" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                     <Button fx:id="btnToggleCategory" onAction="#toggleCategory" style="-fx-text-fill: #ffaa00;" styleClass="menu-button" text="SHOW: ENEMIES">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="enemyButtonsBox" alignment="TOP_CENTER" spacing="8.0" />
                        </content>
                    </ScrollPane>
                     <Button fx:id="btnRandom" onAction="#selectRandom" styleClass="menu-button" text="RANDOM">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                </VBox>

                <VBox alignment="CENTER" rotate="1.5" spacing="16.0" styleClass="main-card" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                    <Label fx:id="skinNameLabel" styleClass="card-subheader" text="ENEMY NAME" wrapText="true" />
                    <StackPane fx:id="previewContainer" />
                     <Button fx:id="btnEditEntity" onAction="#openEntityEditor" style="-fx-text-fill: #00eeff;" styleClass="menu-button" text="EDIT / CREATE ENTITY">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
   
                   <fx:include fx:id="infoCard" source="components/InfoCard.fxml" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" />

                    <Region VBox.vgrow="ALWAYS" />
                </VBox>

            </HBox>
         <VBox alignment="BOTTOM_CENTER" minHeight="40.0" VBox.vgrow="ALWAYS">
            <children>

                    <Button fx:id="btnBack" onAction="#handleBack" styleClass="menu-button, back-button" text="MAIN MENU">
                  <padding>
                     <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                  </padding>
                  <VBox.margin>
                     <Insets />
                  </VBox.margin></Button>
            </children>
            <VBox.margin>
               <Insets bottom="56.0" />
            </VBox.margin>
         </VBox>
        </children>
    </VBox>
</StackPane>
