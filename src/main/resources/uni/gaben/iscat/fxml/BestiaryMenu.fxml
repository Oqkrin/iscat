<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/bestiary-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.BestiaryMenuController">
    <VBox alignment="CENTER" styleClass="menu-background">
        <children>
            <Region minHeight="56.0" prefHeight="56.0" />

            <HBox alignment="CENTER" spacing="48.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                </padding>

                <VBox alignment="TOP_CENTER" spacing="14.0" prefWidth="280.0" maxWidth="300.0" rotate="-1.5" styleClass="glowing-border, secondary-card">
                    <padding><Insets bottom="16.0" left="16.0" right="16.0" top="20.0"/></padding>

                    <Label fx:id="listHeaderLabel" styleClass="card-header" text="ENEMIES" />
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="enemyButtonsBox" alignment="TOP_CENTER" spacing="8.0" />
                        </content>
                    </ScrollPane>
                </VBox>

                <VBox alignment="CENTER" prefHeight="576.0" prefWidth="380.0" maxWidth="400.0" spacing="12.0" rotate="1.5" styleClass="glowing-border, main-card">
                    <padding><Insets bottom="20.0" left="18.0" right="18.0" top="20.0"/></padding>

                    <Label styleClass="card-header" text="PREVIEW"/>
                    <StackPane fx:id="previewContainer" prefHeight="140.0" prefWidth="140.0"/>
                    <Label fx:id="skinNameLabel" styleClass="card-subheader" text="ENEMY NAME" wrapText="true" />

                    <VBox alignment="CENTER" spacing="8.0" maxWidth="Infinity">
                        <Button fx:id="btnToggleCategory" maxWidth="Infinity" onAction="#toggleCategory" style="-fx-text-fill: #ffaa00;" styleClass="menu-button" text="SHOW: ENEMIES" />
                        <Button fx:id="btnRandom" maxWidth="Infinity" onAction="#selectRandom" styleClass="menu-button" text="RANDOM" />
                    </VBox>

                    <Region prefHeight="10.0" VBox.vgrow="ALWAYS" />

                    <Button fx:id="btnBack" maxWidth="Infinity" onAction="#handleBack" styleClass="menu-button, back-button" text="MAIN MENU" />
                </VBox>

                <fx:include fx:id="infoCard" source="components/EntityInfoCard.fxml" />

            </HBox>
            <Region minHeight="56.0" prefHeight="56.0" />
        </children>
    </VBox>
</StackPane>