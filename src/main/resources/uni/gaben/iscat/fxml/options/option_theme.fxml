<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="theme" alignment="CENTER" spacing="24.0" VBox.vgrow="NEVER"
      xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="uni.gaben.iscat.controller.components.options.OptionThemeController">

    <VBox alignment="TOP_CENTER" spacing="16.0" styleClass="glowing-border, controls-card" maxWidth="420.0" minWidth="360.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
        </padding>

        <VBox alignment="CENTER" spacing="4.0">
            <Label styleClass="card-header" text="THEME" />
        </VBox>

        <VBox spacing="10.0" alignment="CENTER" styleClass="theme-modes-box">
            <HBox alignment="CENTER_LEFT" styleClass="theme-mode-row">
                <Label text="Light Mode" styleClass="theme-row-label" />
                <Region HBox.hgrow="ALWAYS" />
                <CheckBox fx:id="lightModeCheck" onAction="#toggleThemeMode" text="" />
            </HBox>

            <HBox alignment="CENTER_LEFT" styleClass="theme-mode-row">
                <Label text="Rainbow Mode" styleClass="theme-row-label" />
                <Region HBox.hgrow="ALWAYS" />
                <CheckBox fx:id="rainbowModeCheck" onAction="#toggleRainbowMode" text="" />
            </HBox>
        </VBox>

        <HBox fx:id="pickerRow1" alignment="CENTER" spacing="8.0" styleClass="color-picker-row" />
        <HBox fx:id="pickerRow2" alignment="CENTER" spacing="8.0" styleClass="color-picker-row" />

        <Region minHeight="4.0" prefHeight="4.0" VBox.vgrow="ALWAYS" />

        <VBox alignment="CENTER" spacing="8.0" styleClass="palette-section">
            <Label text="Premi un selettore, poi un colore" styleClass="palette-hint" />
            <HBox fx:id="paletteHolder" alignment="CENTER" spacing="6" VBox.vgrow="NEVER" styleClass="palette-holder" />
        </VBox>
    </VBox>

    <VBox alignment="CENTER" spacing="16.0" styleClass="glowing-border, theme-card" maxWidth="360.0" minWidth="360.0" HBox.hgrow="NEVER">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <Label styleClass="card-header" text="PREVIEW" />

        <StackPane fx:id="imageArea" minHeight="180.0" maxHeight="180.0" maxWidth="320.0" styleClass="theme-preview-container" VBox.vgrow="NEVER">
            <ImageView fx:id="themePreview" fitHeight="180" fitWidth="320" preserveRatio="true" />
            <Button fx:id="pickImageBtn" onAction="#onImagePick" text="Pick Image" styleClass="action-button" StackPane.alignment="CENTER" />
        </StackPane>

        <HBox alignment="CENTER" spacing="12.0" styleClass="theme-navigation-row">
            <Button fx:id="prevThemeBtn" onAction="#prevTheme" text="&lt;" styleClass="nav-button" />
            <Button fx:id="addImageBtn" text="ADD IMAGE" visible="false" managed="false" styleClass="action-button" />
            <Button fx:id="nextThemeBtn" onAction="#nextTheme" text="&gt;" styleClass="nav-button" />
        </HBox>
    </VBox>

    <VBox fx:id="hiddenPickers" managed="false" visible="false">
        <ColorPicker fx:id="accentPrimary" />
        <ColorPicker fx:id="accentSecondary" />
        <ColorPicker fx:id="accentTernary" />
        <ColorPicker fx:id="bgPrimary" />
    </VBox>

</HBox>