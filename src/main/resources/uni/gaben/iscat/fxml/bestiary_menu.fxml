<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/bestiary-menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.BestiaryMenuController">
   <VBox alignment="CENTER">
      <children>
            <Region minHeight="56.0" prefHeight="56.0" />
            <HBox alignment="CENTER" spacing="32.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                </padding>

                      <VBox alignment="TOP_CENTER" spacing="14.0" HBox.hgrow="ALWAYS">

                           <Label fx:id="listHeaderLabel" styleClass="card-header" text="ENEMIES" />

                           <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                         <content>
                             <VBox fx:id="enemyButtonsBox" alignment="TOP_CENTER" spacing="8.0" />
                         </content>
                     </ScrollPane>
                </VBox>

                      <VBox alignment="CENTER" spacing="16.0" HBox.hgrow="ALWAYS">

                           <StackPane fx:id="previewContainer" />
                     <Label fx:id="skinNameLabel" styleClass="card-header" text="ENEMY NAME" wrapText="true" />

                           <Button fx:id="btnToggleCategory" alignment="CENTER" onAction="#toggleCategory" style="-fx-text-fill: #ffaa00;" styleClass="menu-button" text="SHOW: ENEMIES">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>

                           <Button fx:id="btnRandom" alignment="CENTER" onAction="#selectRandom" styleClass="menu-button" text="RANDOM">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                     <Button fx:id="btnDescription" alignment="CENTER" onAction="#showDescription" styleClass="menu-button" text="DESCRIPTION">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                     <Button fx:id="btnStats" alignment="CENTER" onAction="#showStats" styleClass="menu-button" text="STATS">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                     <Button fx:id="btnExtra" alignment="CENTER" onAction="#showExtra" styleClass="menu-button" text="EXTRA">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                     <Button fx:id="btnBack" alignment="CENTER" onAction="#handleBack" styleClass="back-button" text="MAIN MENU">
                  <padding>
                     <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                  </padding>
               </Button>
                </VBox>
                 <VBox alignment="TOP_CENTER" rotate="2.0" spacing="10.0" styleClass="glowing-border, secondary-card">
                     <padding>
                  <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
               </padding>
                     <Label fx:id="rightCardHeader" styleClass="card-header" text="DESCRIPTION!" />
                     <TextArea fx:id="description" VBox.vgrow="ALWAYS" />
                 </VBox>
            </HBox>
         <Region minHeight="56.0" prefHeight="56.0" />
      </children>
   </VBox>
</StackPane>
