<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/scenes/bestiary-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.screens.bestiary.BestiaryMenuController">

    <BorderPane fx:id="rootPane" styleClass="menu-background">
        <top>
            <Region minHeight="56.0" prefHeight="56.0"/>
        </top>

        <center>
            <HBox alignment="CENTER" spacing="32.0">
                <padding>
                    <Insets bottom="16.0" left="32.0" right="32.0" top="16.0"/>
                </padding>

                <VBox alignment="TOP_CENTER" maxWidth="270.0" minWidth="190.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="TOP_CENTER" rotate="-2.0" spacing="8.0" styleClass="glowing-border, secondary-card" VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/></padding>
                        <Label styleClass="card-header" text="ENEMIES"/>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="enemyButtonsBox" alignment="TOP_CENTER" spacing="8.0" />
                            </content>
                        </ScrollPane>
                    </VBox>
                </VBox>

                <VBox alignment="CENTER" maxWidth="300.0" minWidth="220.0" spacing="16.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" rotate="-1.0" spacing="14.0" styleClass="glowing-border, main-card">
                        <padding><Insets bottom="20.0" left="18.0" right="18.0" top="20.0"/></padding>
                        <StackPane fx:id="previewContainer" prefHeight="140.0" prefWidth="140.0"/>
                        <Label fx:id="skinNameLabel" styleClass="card-header" text="ENEMY NAME" wrapText="true"/>
                        <Button maxWidth="Infinity" onAction="#selectRandom" styleClass="menu-button" text="RANDOM"/>
                    </VBox>
                </VBox>

                <VBox alignment="TOP_CENTER" maxWidth="320.0" minWidth="240.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="TOP_CENTER" rotate="2.0" spacing="10.0" styleClass="glowing-border, secondary-card" VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/></padding>
                        <Label styleClass="card-header" text="DESCRIPTION!"/>
                        <TextArea fx:id="description" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </VBox>
            </HBox>
        </center>

        <bottom>
            <HBox alignment="CENTER" prefHeight="56.0">
                <Button onAction="#handleBack" styleClass="back-button" text="ESCI"/>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>