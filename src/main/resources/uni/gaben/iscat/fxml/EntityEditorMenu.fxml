<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane minHeight="720.0" minWidth="1024.0" stylesheets="@../styles/screens/entity-editor-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.menus.EntityEditorMenuController">
    <VBox alignment="CENTER" styleClass="menu-background" VBox.vgrow="ALWAYS">
        <children>
            <!-- Top spacer -->
            <Region minHeight="12.0" VBox.vgrow="NEVER" />

            <!-- Main content row: editor left, preview right -->
            <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="12.0" left="20.0" right="20.0" top="12.0" />
                </padding>

                <!-- ========== Left Panel: Form Editor ========== -->
                <VBox alignment="TOP_CENTER" spacing="10.0" HBox.hgrow="ALWAYS" styleClass="glowing-border, editor-panel">

                    <!-- Header row: title + entity selector -->
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label fx:id="lblEditorTitle" styleClass="card-header" text="ENTITY EDITOR" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="comboEntitySelect" maxWidth="220.0" promptText="Select Entity..." />
                    </HBox>

                    <!-- Scrollable form -->
                    <ScrollPane styleClass="editor-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                        <content>
                            <Accordion fx:id="categoryAccordion">
                                <panes>
                                    <TitledPane text="Identity" expanded="true">
                                        <VBox fx:id="paneIdentity" spacing="8.0" />
                                    </TitledPane>
                                    <TitledPane text="Visuals">
                                        <VBox fx:id="paneVisuals" spacing="8.0" />
                                    </TitledPane>
                                    <TitledPane text="Physics &amp; Combat">
                                        <VBox fx:id="panePhysics" spacing="8.0" />
                                    </TitledPane>
                                    <TitledPane text="Behavioural">
                                        <VBox fx:id="paneBehavioural" spacing="8.0" />
                                    </TitledPane>
                                    <TitledPane text="Advanced AI" fx:id="tpAdvancedAI">
                                        <VBox fx:id="paneAdvancedAI" spacing="14.0" />
                                    </TitledPane>
                                    <TitledPane text="Audio">
                                        <VBox fx:id="paneAudio" spacing="8.0" />
                                    </TitledPane>
                                </panes>
                            </Accordion>
                        </content>
                    </ScrollPane>
                </VBox>

                <!-- ========== Right Panel: Preview + Actions ========== -->
                <VBox alignment="CENTER" spacing="10.0" minWidth="280.0" maxWidth="360.0" styleClass="glowing-border, editor-panel">

                    <Label styleClass="card-header" text="PREVIEW" />
                    <StackPane fx:id="previewContainer" minHeight="140.0" minWidth="140.0" maxHeight="220.0" maxWidth="220.0" />
                    <Label fx:id="skinNameLabel" styleClass="card-subheader" text="ENTITY PREVIEW" wrapText="true" maxWidth="Infinity" />
                    <Label fx:id="lblOriginPath" text="Origin: N/A" wrapText="true" maxWidth="Infinity" />

                    <Region VBox.vgrow="ALWAYS" />

                    <!-- Action buttons — semantic colour from CSS, no inline style -->
                    <VBox alignment="CENTER" spacing="6.0">
                        <Button fx:id="btnApply"         maxWidth="Infinity" onAction="#handleApply"         styleClass="menu-button, btn-apply"         text="APPLY RUNTIME" />
                        <Button fx:id="btnSaveOverwrite" maxWidth="Infinity" onAction="#handleSaveOverwrite" styleClass="menu-button, btn-save-overwrite" text="SAVE (OVERWRITE)" />
                        <Button fx:id="btnSaveNew"       maxWidth="Infinity" onAction="#handleSaveNew"       styleClass="menu-button, btn-save-new"       text="SAVE AS NEW CUSTOM" />
                    </VBox>

                    <Region VBox.vgrow="NEVER" minHeight="8.0" />

                    <Button fx:id="btnBack" maxWidth="Infinity" onAction="#handleBack" styleClass="menu-button, back-button" text="BACK TO BESTIARY" />
                </VBox>

            </HBox>

            <!-- Bottom spacer -->
            <Region minHeight="12.0" VBox.vgrow="NEVER" />
        </children>
    </VBox>
</StackPane>
