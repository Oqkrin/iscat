<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane alignment="CENTER" rotate="-1.5" scaleX="1.25" scaleY="1.25" maxWidth="450.0" minWidth="380.0" VBox.vgrow="NEVER"
           xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="uni.gaben.iscat.controller.components.options.OptionAccountController">

    <Region styleClass="glowing-border, controls-card" />

    <VBox alignment="TOP_CENTER" spacing="16.0">
        <padding>
            <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
        </padding>

        <VBox alignment="CENTER" spacing="4.0">
            <Label styleClass="card-header" text="ACCOUNT" />
        </VBox>

        <Region minHeight="4.0" prefHeight="4.0" />

        <VBox spacing="12.0" alignment="CENTER" maxWidth="Infinity">
            <Button maxWidth="Infinity" prefHeight="38.0" onAction="#changeUsername" text="CHANGE USERNAME" />
            <Button maxWidth="Infinity" prefHeight="38.0" onAction="#changePassword" text="CHANGE PASSWORD" />
            <Button maxWidth="Infinity" prefHeight="38.0" onAction="#resetAccount" text="RESET ACCOUNT" />

            <Region minHeight="8.0" prefHeight="8.0" />

            <Button maxWidth="Infinity" prefHeight="38.0" onAction="#deleteAccount" styleClass="danger-button" text="DELETE ACCOUNT" />
        </VBox>
    </VBox>
</StackPane>