<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/game.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.game.GameOverMenuController">

    <VBox alignment="CENTER" spacing="24.0" styleClass="game-pause-overlay">
        <padding>
            <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
        </padding>

        <Label styleClass="pause-title" text="YOU DIED">
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding></Label>

        <Button fx:id="retryBtn" alignment="CENTER" onAction="#handleRetry" styleClass="pulsante-menu, primario" text="TRY AGAIN">
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding></Button>
        <Button fx:id="menuBtn" alignment="CENTER" onAction="#handleQuitToMenu" styleClass="pulsante-menu" text="MAIN MENU">
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding></Button>
        <Button fx:id="quitBtn" alignment="CENTER" onAction="#handleQuitGame" styleClass="pulsante-menu, pericolo" text="QUIT">
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding></Button>
    </VBox>
</StackPane>
