<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane fx:id="rootPane" style="-fx-background-color: transparent;" stylesheets="@../styles/screens/login-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.menus.LoginMenuController">
   <children>
      <VBox fx:id="contentBox" alignment="CENTER" spacing="20.0" style="-fx-background-color: transparent;">
         <children>

            <StackPane fx:id="headerStack" alignment="CENTER">
               <children>
                  <Label fx:id="welcomeTitle" alignment="CENTER" text="WELCOME TO ISCAT">
                     <styleClass>
                        <String fx:value="login-title" />
                     </styleClass>
                  </Label>
                  <Label fx:id="loggedInUserLabel" alignment="CENTER" opacity="0.0" managed="false">
                     <styleClass>
                        <String fx:value="login-user-success" />
                     </styleClass>
                  </Label>
               </children>
            </StackPane>

            <HBox alignment="CENTER">
               <children>
                  <FontIcon fx:id="loginIcon" iconLiteral="fas-id-card-alt">
                     <styleClass>
                        <String fx:value="login-icon" />
                     </styleClass>
                     <HBox.margin>
                        <Insets left="12.0" right="12.0" />
                     </HBox.margin>
                  </FontIcon>
                  <TextField fx:id="usernameField" alignment="CENTER" promptText="Nome Utente" onAction="#onUsernameAction">
                     <styleClass>
                        <String fx:value="login-input-field" />
                     </styleClass>
                  </TextField>
               </children>
            </HBox>

            <HBox alignment="CENTER">
               <children>
                  <FontIcon fx:id="passwdIcon" iconLiteral="fas-asterisk">
                     <styleClass>
                        <String fx:value="login-icon" />
                     </styleClass>
                     <HBox.margin>
                        <Insets left="12.0" right="12.0" />
                     </HBox.margin>
                  </FontIcon>
                  <PasswordField fx:id="passwordField" alignment="CENTER" promptText="Password" onAction="#onPasswordAction">
                     <styleClass>
                        <String fx:value="login-input-field" />
                     </styleClass>
                  </PasswordField>
               </children>
            </HBox>

            <Label fx:id="statusLabel" alignment="CENTER" ellipsisString="">
               <styleClass>
                  <String fx:value="login-text-status" />
               </styleClass>
            </Label>

         </children>
      </VBox>
   </children>
</StackPane>