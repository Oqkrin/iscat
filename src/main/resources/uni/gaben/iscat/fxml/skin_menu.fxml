<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" stylesheets="@../styles/skin-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.menus.skin_menu.SkinMenuController">
   <top>
      <VBox alignment="TOP_CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="40.0" />
         </padding>
         <Label text="PLAYER SKINS" textFill="WHITE">
            <font>
               <Font name="System Bold" size="80.0" />
            </font>
         </Label>
      </VBox>
   </top>
   <center>
      <HBox alignment="CENTER" spacing="80.0" BorderPane.alignment="CENTER">
         <GridPane fx:id="skinGrid" alignment="CENTER" hgap="15.0" minHeight="0" minWidth="0" vgap="15.0" />            <VBox fx:id="previewBox" alignment="CENTER" spacing="30.0" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 20;">
            <padding>
               <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <Label text="PREVIEW" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="35.0" />
               </font>
            </Label>

         <StackPane fx:id="previewContainer" prefWidth="160.0" prefHeight="160.0" />

            <Label fx:id="skinNameLabel" ellipsisString="" text="SELEZIONA UNA SKIN" textFill="#00ffcc">
               <font>
                  <Font name="System Italic" size="25.0" />
               </font>
            </Label>

            <VBox alignment="CENTER" spacing="15.0">
               <Button ellipsisString="" onAction="#handleConfirm" styleClass="confirm-button" text="CONFERMA" />
               <Button ellipsisString="" onAction="#handleBack" styleClass="back-button" text="ANNULLA" />
            </VBox>
         </VBox>
      </HBox>
   </center>
</BorderPane>
