<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="skinStackPane" stylesheets="@../styles/scenes/skin-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.iscat_screens.skin_selection.SkinMenuController">

   <BorderPane styleClass="menu-background">

      <top>
         <Region minHeight="60.0" prefHeight="60.0" />
      </top>

      <center>
         <HBox alignment="CENTER" spacing="48.0">
            <padding>
               <Insets bottom="20.0" left="48.0" right="48.0" top="20.0" />
            </padding>

            <!-- LEFT: Skin grid -->
            <VBox alignment="TOP_CENTER" maxWidth="480.0" minWidth="300.0" spacing="16.0" HBox.hgrow="ALWAYS">
               <VBox alignment="TOP_CENTER" rotate="-1.5" spacing="12.0" styleClass="glowing-border, secondary-card" VBox.vgrow="ALWAYS">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <Label styleClass="card-header" text="SKINS" />
                  <GridPane fx:id="skinGrid" alignment="CENTER" hgap="15.0" vgap="15.0" VBox.vgrow="ALWAYS" />
                  <Label fx:id="underGridLabel" alignment="CENTER" styleClass="card-subheader" text="SELEZIONA UNA SKIN!" />
               </VBox>
            </VBox>

            <!-- RIGHT: Preview -->
            <VBox fx:id="previewBox" alignment="CENTER" maxWidth="320.0" minWidth="240.0" spacing="20.0" HBox.hgrow="ALWAYS">
               <VBox alignment="CENTER" rotate="1.5" spacing="16.0" styleClass="glowing-border, main-card">
                  <padding>
                     <Insets bottom="28.0" left="24.0" right="24.0" top="28.0" />
                  </padding>
                  <Label styleClass="card-header" text="PREVIEW" />
                  <StackPane fx:id="previewContainer" prefHeight="160.0" prefWidth="160.0" />
                  <Label fx:id="skinNameLabel" styleClass="card-subheader" text="Skin Name" />
                  <Button fx:id="confirmBtn" maxWidth="Infinity" onAction="#handleConfirm" styleClass="menu-button, play-button" text="CONFERMA" />
                  <Button fx:id="randomBtn" maxWidth="Infinity" onAction="#selectRandom" styleClass="menu-button" text="RANDOM" />
               </VBox>
            </VBox>

         </HBox>
      </center>

      <bottom>
         <HBox alignment="CENTER" prefHeight="80.0">
            <Button fx:id="cancelBtn" onAction="#handleBack" styleClass="back-button" text="ANNULLA" />
         </HBox>
      </bottom>

   </BorderPane>
</StackPane>
