<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="skinStackPane" minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/screens/skin-menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.SkinMenuController">
   <VBox>
      <children>
         <Region minHeight="56.0" prefHeight="56.0" VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER" spacing="48.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
                </padding>

                                  <VBox alignment="TOP_CENTER" maxWidth="440.0" minWidth="280.0" spacing="14.0" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="40.0" />
                    </padding>

                                      <VBox alignment="TOP_CENTER" rotate="-1.5" spacing="10.0" styleClass="glowing-border, secondary-card" VBox.vgrow="ALWAYS">
                        <padding>
                     <Insets bottom="16.0" left="16.0" right="16.0" top="20.0" />
                  </padding>

                                          <Label styleClass="card-header" text="SKINS" />

                                          <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <StackPane alignment="CENTER">
                                    <padding>
                                        <Insets bottom="30.0" left="16.0" right="16.0" top="50.0" />
                                    </padding>
                                    <children>
                                        <GridPane fx:id="skinGrid" alignment="CENTER" hgap="12.0" vgap="12.0" />
                                    </children>
                                </StackPane>
                            </content>
                        </ScrollPane>

                                          <Label fx:id="underGridLabel" alignment="CENTER" styleClass="card-subheader" text="SELEZIONA UNA SKIN!" />
                    </VBox>
                </VBox>

                                  <VBox fx:id="previewBox" alignment="CENTER" maxWidth="340.0" minWidth="260.0" spacing="16.0" HBox.hgrow="ALWAYS">
                    <VBox alignment="CENTER" rotate="1.5" spacing="12.0" styleClass="glowing-border, main-card">
                        <padding>
                     <Insets bottom="20.0" left="18.0" right="18.0" top="20.0" />
                  </padding>
                        <Label styleClass="card-header" text="PREVIEW" />

                                          <StackPane fx:id="previewContainer" prefHeight="140.0" prefWidth="140.0" />

                                          <Label fx:id="skinNameLabel" styleClass="card-subheader" text="Skin Name" wrapText="true" />

                                          <HBox alignment="CENTER" spacing="12.0">
                            <Button fx:id="btnDescription" minWidth="-Infinity" onAction="#showDescription" prefWidth="110.0" styleClass="menu-button" text="INFO" />
                            <Button fx:id="btnStats" minWidth="-Infinity" onAction="#showStats" prefWidth="110.0" styleClass="menu-button" text="STATS" />
                            <Button fx:id="btnExtra" minWidth="-Infinity" onAction="#showExtra" prefWidth="110.0" styleClass="menu-button" text="EXTRA" />
                        </HBox>

                                          <Separator prefWidth="200.0" style="-fx-opacity: 0.3;" />

                                          <Button fx:id="confirmBtn" maxWidth="Infinity" onAction="#handleConfirm" styleClass="menu-button, play-button" text="CONFERMA" />
                        <Button fx:id="randomBtn" maxWidth="Infinity" onAction="#selectRandom" styleClass="menu-button" text="RANDOM" />
                        <Button fx:id="cancelBtn" maxWidth="Infinity" onAction="#handleBack" styleClass="menu-button, back-button" text="ANNULLA" />
                    </VBox>
                </VBox>

                                  <fx:include fx:id="infoCard" source="InfoCard.fxml" />

                              </HBox>
         <Region minHeight="56.0" prefHeight="56.0" VBox.vgrow="ALWAYS" />
      </children>
   </VBox>
</StackPane>
