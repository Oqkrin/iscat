<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootPane" managed="false" style="-fx-background-color: rgba(0, 0, 0, 0.75);" visible="false" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.controller.components.ConfirmationOverlayController">

    <VBox fx:id="dialog" alignment="CENTER" rotate="1.0" spacing="16.0" styleClass="glowing-border, main-card">
        <padding>
            <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
        </padding>

        <Label fx:id="titleLabel" styleClass="card-header" text="SEI SICURO?">
         <padding>
            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
         </padding></Label>
        <Label fx:id="descLabel" styleClass="card-subheader" text="L'azione è irreversibile." textAlignment="CENTER" wrapText="true">
         <padding>
            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
         </padding></Label>

        <TextField fx:id="normalTextField" managed="false" promptText="Inserisci testo..." styleClass="menu-input-field" visible="false">
         <padding>
            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
         </padding></TextField>
        <PasswordField fx:id="passwordTextField" managed="false" promptText="Inserisci password..." styleClass="menu-input-field" visible="false">
         <padding>
            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
         </padding></PasswordField>
        <Button fx:id="keybindBtn" managed="false" text="CLICCA PER ASSEGNARE" visible="false">
         <padding>
            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
         </padding></Button>

        <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="yesBtn" onAction="#handleYes" styleClass="menu-button, play-button" text="SÌ">
            <padding>
               <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
            </padding></Button>
            <Button fx:id="noBtn" onAction="#handleNo" styleClass="menu-button, back-button" text="NO">
            <padding>
               <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
            </padding></Button>
        </HBox>
    </VBox>
</StackPane>
