<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@../styles/options-menu.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="uni.gaben.iscat.iscat_screens.options.OptionsMenuController">

    <AnchorPane fx:id="paneMaster" styleClass="menu-background">
        <VBox fx:id="mainOptions" alignment="TOP_CENTER" rotate="-6.0" spacing="15.0"
              styleClass="option-card, video-card" AnchorPane.leftAnchor="50.0" AnchorPane.topAnchor="50.0">
            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
            <Label styleClass="card-header" text="DISPLAY" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="UI Scale" styleClass="control-label" />
                <Slider fx:id="scaleSlider" blockIncrement="2.0" max="96.0" min="1.0" value="64.0" />
            </HBox>
            <CheckBox fx:id="checkFps" onAction="#toggleFPSVisible" styleClass="modern-checkbox" text="SHOW FPS OVERLAY" />
            <CheckBox fx:id="FullscreenCheck" onAction="#toggleFullscreen" styleClass="modern-checkbox" text="FULLSCREEN MODE" />
        </VBox>

        <VBox alignment="TOP_CENTER" rotate="2.0" spacing="15.0"
              styleClass="option-card, audio-card" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
            <Label styleClass="card-header" text="AUDIO" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="MASTER" styleClass="control-label" />
                <Slider fx:id="BGMSlider1" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="BGM" styleClass="control-label" />
                <Slider fx:id="BGMSlider" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="SFX" styleClass="control-label" />
                <Slider fx:id="SFXSlider" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

        <VBox alignment="TOP_CENTER" rotate="-2.0" spacing="10.0"
              styleClass="option-card, theme-card" AnchorPane.leftAnchor="350.0" AnchorPane.topAnchor="50.0">
            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
            <Label styleClass="card-header" text="THEME" />
            <CheckBox fx:id="lightModeCheck" onAction="#toggleThemeMode" text="LIGHT MODE" />

            <GridPane hgap="5" vgap="5" alignment="CENTER">
                <ColorPicker fx:id="accentPrimary" onAction="#onPrimary" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ColorPicker fx:id="accentSecondary" onAction="#onSecondary" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <ColorPicker fx:id="accentTernary" onAction="#onTernary" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ColorPicker fx:id="bgPrimary" onAction="#onBgPrimary" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            </GridPane>

            <ImageView fx:id="themePreview" preserveRatio="true" />

            <HBox alignment="CENTER" spacing="10.0">
                <Button onAction="#prevTheme" text="&lt;" />
                <Button fx:id="ImagePicker" onAction="#onImagePick" text="Pick Image" />
                <Button onAction="#nextTheme" text="&gt;" />
            </HBox>
        </VBox>

        <VBox alignment="TOP_CENTER" rotate="3.0" spacing="10.0"
              styleClass="option-card, danger-card" AnchorPane.leftAnchor="50.0" AnchorPane.bottomAnchor="50.0">
            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
            <Label styleClass="card-header" text="ACCOUNT" />
            <Button fx:id="ResetAccountBtn" onAction="#resetAccount" text="Reset Account" maxWidth="Infinity" />
            <Button fx:id="DeleteAccountBtn" onAction="#deleteAccount" text="Delete Account" maxWidth="Infinity" style="-fx-text-fill: red;" />
        </VBox>

        <VBox fx:id="controlsBox" alignment="TOP_CENTER" rotate="-4.0" spacing="10.0"
              styleClass="option-card, controls-card" AnchorPane.rightAnchor="50.0" AnchorPane.bottomAnchor="50.0">
            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>
            <Label styleClass="card-header" text="KEYBINDINGS" />
            <Button fx:id="walkUp" onAction="#changeControl" text="W" />
            <HBox spacing="5" alignment="CENTER">
                <Button fx:id="walkLeft" onAction="#changeControl" text="A" />
                <Button fx:id="walkDown" onAction="#changeControl" text="S" />
                <Button fx:id="walkRight" onAction="#changeControl" text="D" />
            </HBox>
            <Button fx:id="dash1" onAction="#changeControl" text="Dash: Space" />
            <Button fx:id="dash2" onAction="#changeControl" text="Dash: Mouse" />
            <Button fx:id="esc" onAction="#changeControl" text="Pause" />
            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="resetControlsBtn" onAction="#resetControls" text="RESTORE DEFAULTS" />
        </VBox>

        <Button fx:id="ExitBtn" onAction="#handleBack" styleClass="back-button" text="Main Menu"
                AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="20.0" />
    </AnchorPane>
</StackPane>