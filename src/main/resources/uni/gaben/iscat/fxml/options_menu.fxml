<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" stylesheets="@../styles/options-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.menus.options_menu.OptionsMenuController">
   <top>
      <VBox alignment="TOP_CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="40.0" />
         </padding>
         <Label text="OPTIONS" textFill="WHITE">
            <font>
               <Font name="System Bold" size="80.0" />
            </font>
         </Label>
      </VBox>
   </top>
   <center>
      <StackPane prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>            <VBox fx:id="mainOptions" alignment="CENTER" spacing="30.0" style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 20;">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <Label text="---- Audio ----" />
               <HBox alignment="CENTER" prefHeight="0.0" prefWidth="290.0" spacing="8.0">
                  <children>
      
                           <Label fx:id="skinNameLabel" ellipsisString="" text="BGM AUDIO" textFill="#00ffcc">
                        <font>
                           <Font name="System Italic" size="25.0" />
                        </font>
                     </Label>
                     <Slider fx:id="BGMSlider" />
                  </children>
               </HBox>
               <HBox alignment="CENTER" prefHeight="0.0" prefWidth="290.0" spacing="8.0">
                  <children>
                     <Label fx:id="skinNameLabel1" ellipsisString="" text="SFX AUDIO" textFill="#00ffcc">
                        <font>
                           <Font name="System Italic" size="25.0" />
                        </font>
                     </Label>
                     <Slider fx:id="SFXSlider" />
                  </children>
               </HBox>
               <Label text="---- Miscelaneus ----" />
               <HBox alignment="CENTER" prefHeight="0.0" prefWidth="290.0" spacing="8.0">
                  <children>
                     <Label fx:id="skinNameLabel11" ellipsisString="" text="scale" textFill="#00ffcc">
                        <font>
                           <Font name="System Italic" size="25.0" />
                        </font>
                     </Label>
                     <Slider fx:id="scaleSlider" blockIncrement="2.0" max="96.0" min="1.0" onDragDetected="#updateScale" value="64.0" />
                  </children>
               </HBox>
               <CheckBox fx:id="checkFps" mnemonicParsing="false" onAction="#toggleFPSVisible" text="MOSTRA FPS" />
               <CheckBox fx:id="FullscreenCheck" mnemonicParsing="false" onAction="#toggleFullscreen" text="FULLSCREEN" />
               <Button fx:id="ControlsBtn" ellipsisString="" onAction="#showControls" styleClass="back-button" text="Controls" />
            <Button fx:id="ExitBtn" ellipsisString="" onAction="#handleBack" styleClass="back-button" text="ESCI" />
            </VBox>
            <VBox fx:id="controlsBox" alignment="CENTER" prefHeight="200.0" prefWidth="100.0" visible="false" StackPane.alignment="CENTER">
               <children>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Walk up" />
                        <Button fx:id="walkUp" mnemonicParsing="false" onAction="#changeControl" text="W" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Walk left" />
                        <Button fx:id="walkLeft" mnemonicParsing="false" onAction="#changeControl" text="A" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Walk down" />
                        <Button fx:id="walkDown" mnemonicParsing="false" onAction="#changeControl" text="S" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Walk right" />
                        <Button fx:id="walkRight" mnemonicParsing="false" onAction="#changeControl" text="D" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Dash 1" />
                        <Button fx:id="dash1" mnemonicParsing="false" onAction="#changeControl" text="Space" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Dash 2" />
                        <Button fx:id="dash2" mnemonicParsing="false" onAction="#changeControl" text="Middle mouse" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label text="Pause Game" />
                        <Button mnemonicParsing="false" onAction="#changeControl" text="ESC" />
                     </children>
                  </HBox>
                  <Button fx:id="resetControlsBtn" mnemonicParsing="false" onAction="#resetControls" text="RESET" />
                  <Button fx:id="saveAndCloseControlsBtn" mnemonicParsing="false" onAction="#saveAndCloseControls" text="SAVE AND EXIT" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>
