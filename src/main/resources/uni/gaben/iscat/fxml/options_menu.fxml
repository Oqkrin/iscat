                     </children>
                  </HBox>
                  <Button fx:id="resetControlsBtn" mnemonicParsing="false" onAction="#resetControls" text="RESET" />
               </children>
            </VBox>
            <VBox fx:id="mainOptions" alignment="CENTER" layoutX="6.0" layoutY="14.0" prefHeight="345.0" prefWidth="351.0" spacing="30.0" style="-fx-background-radius: 20;">
