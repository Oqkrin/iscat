<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="720.0" minWidth="1280.0" stylesheets="@../styles/scenes/options-menu.css" xmlns="http://javafx.com/javafx/" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.gaben.iscat.screens.options.OptionsMenuController">

    <VBox fx:id="paneMaster" styleClass="menu-background" VBox.vgrow="ALWAYS">

        <Region minHeight="56.0" prefHeight="56.0" />

        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <GridPane alignment="CENTER" hgap="32.0">
                    <padding>
                        <Insets bottom="16.0" left="32.0" right="32.0" top="16.0" />
                    </padding>

                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33" />
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints percentHeight="100" vgrow="ALWAYS" />
                    </rowConstraints>

                    <VBox alignment="TOP_CENTER" maxWidth="295.0" minWidth="220.0" spacing="20.0" GridPane.columnIndex="0" VBox.vgrow="ALWAYS">
                  <Region VBox.vgrow="ALWAYS" />
                        <VBox fx:id="display" alignment="TOP_CENTER" rotate="-3.0" spacing="12.0" styleClass="glowing-border, video-card" VBox.vgrow="NEVER">
                            <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                            <Label styleClass="card-header" text="DISPLAY" />
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label styleClass="control-label" text="UI Scale" />
                                <Slider fx:id="scaleSlider" blockIncrement="2.0" max="96.0" min="1.0" value="64.0" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <CheckBox fx:id="checkFps" onAction="#toggleFPSVisible" styleClass="modern-checkbox" text="SHOW FPS OVERLAY" />
                            <CheckBox fx:id="FullscreenCheck" onAction="#toggleFullscreen" styleClass="modern-checkbox" text="FULLSCREEN MODE" />
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <VBox fx:id="account" alignment="TOP_CENTER" rotate="1.5" spacing="10.0" styleClass="glowing-border, danger-card" VBox.vgrow="NEVER">
                            <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                            <Label styleClass="card-header" text="ACCOUNT" />
                            <Button fx:id="ResetAccountBtn" onAction="#resetAccount" text="Reset Account" />
                            <Button fx:id="DeleteAccountBtn" onAction="#deleteAccount" style="-fx-text-fill: red;" text="Delete Account" />
                        </VBox>
                  <Region VBox.vgrow="ALWAYS" />
                    </VBox>

                    <VBox fx:id="theme" alignment="TOP_CENTER" maxWidth="370.0" minWidth="280.0" rotate="-1.0" spacing="12.0" styleClass="glowing-border, theme-card" GridPane.columnIndex="1" VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                        <Label styleClass="card-header" text="THEME" />
                        <StackPane minHeight="80.0" VBox.vgrow="ALWAYS">
                            <ImageView fx:id="themePreview" preserveRatio="true" />
                        </StackPane>
                        <HBox alignment="CENTER" spacing="10.0">
                            <Button onAction="#prevTheme" text="&lt;" />
                            <Button fx:id="ImagePicker" onAction="#onImagePick" text="Pick Image" HBox.hgrow="ALWAYS" />
                            <Button onAction="#nextTheme" text="&gt;" />
                        </HBox>
                        <CheckBox fx:id="lightModeCheck" onAction="#toggleThemeMode" text="LIGHT MODE" />
                        <CheckBox fx:id="RainbowModeCheck" onAction="#toggleRainbowMode" text="RAINBOW MODE" />
                        <GridPane alignment="CENTER" hgap="8.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                            <ColorPicker fx:id="accentPrimary" onAction="#onPrimary" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <ColorPicker fx:id="accentSecondary" onAction="#onSecondary" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <ColorPicker fx:id="accentTernary" onAction="#onTernary" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <ColorPicker fx:id="bgPrimary" onAction="#onBgPrimary" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        </GridPane>
                  <HBox fx:id="paletteHolder" VBox.vgrow="NEVER" />
                    </VBox>

                    <VBox alignment="TOP_CENTER" maxWidth="295.0" minWidth="220.0" spacing="20.0" GridPane.columnIndex="2" VBox.vgrow="ALWAYS">
                        <VBox fx:id="audio" alignment="TOP_CENTER" rotate="1.0" spacing="12.0" styleClass="glowing-border, audio-card" VBox.vgrow="NEVER">
                            <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                            <Label styleClass="card-header" text="AUDIO" />
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label styleClass="control-label" text="MASTER" />
                                <Slider fx:id="masterSlider" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label styleClass="control-label" text="BGM" />
                                <Slider fx:id="BGMSlider" HBox.hgrow="ALWAYS" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label styleClass="control-label" text="SFX" />
                                <Slider fx:id="SFXSlider" HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <VBox fx:id="keybinds" alignment="TOP_CENTER" rotate="-2.0" spacing="8.0" styleClass="glowing-border, controls-card" VBox.vgrow="NEVER">
                            <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                            <Label styleClass="card-header" text="KEYBINDINGS" />
                            <Button fx:id="walkUp" onAction="#changeControl" text="W" />
                            <HBox alignment="CENTER" spacing="5.0">
                                <Button fx:id="walkLeft" onAction="#changeControl" text="A" />
                                <Button fx:id="walkDown" onAction="#changeControl" text="S" />
                                <Button fx:id="walkRight" onAction="#changeControl" text="D" />
                            </HBox>
                            <Button fx:id="dash1" onAction="#changeControl" text="Dash: Space" />
                            <Button fx:id="dash2" onAction="#changeControl" text="Dash: Mouse" />
                            <Button fx:id="esc" onAction="#changeControl" text="Pause" />
                            <Button fx:id="resetControlsBtn" onAction="#resetControls" text="RESTORE DEFAULTS" />
                        </VBox>
                    </VBox>
                </GridPane>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" prefHeight="56.0">
            <Button fx:id="ExitBtn" onAction="#handleBack" styleClass="back-button" text="Main Menu" />
        </HBox>
    </VBox>
</StackPane>
