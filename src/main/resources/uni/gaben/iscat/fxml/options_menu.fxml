                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
               <children>
                  <Label text="---- Miscelaneus ----" />
                  <HBox alignment="CENTER" prefHeight="0.0" prefWidth="290.0" spacing="8.0">
                     <children>
                        <Label fx:id="skinNameLabel11" ellipsisString="" text="scale" textFill="#00ffcc">
                           <font>
                              <Font name="System Italic" size="25.0" />
                           </font>
                        </Label>
                        <Slider fx:id="scaleSlider" blockIncrement="2.0" max="96.0" min="1.0" onDragDetected="#updateScale" value="64.0" />
                     </children>
                  </HBox>
                  <CheckBox fx:id="checkFps" mnemonicParsing="false" onAction="#toggleFPSVisible" text="MOSTRA FPS" />
