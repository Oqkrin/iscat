                           </font>
                        </Label>
                        <Slider fx:id="BGMSlider1" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="0.0" prefWidth="290.0" spacing="8.0">
                     <children>
                        <Label fx:id="skinNameLabel" ellipsisString="" text="BGM AUDIO" textFill="#00ffcc">
                           <font>
                              <Font name="System Italic" size="25.0" />
                           </font>
                        </Label>
                        <Slider fx:id="BGMSlider" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="0.0" prefWidth="290.0" spacing="8.0">
                     <children>
                        <Label fx:id="skinNameLabel1" ellipsisString="" text="SFX AUDIO" textFill="#00ffcc">
                           <font>
                              <Font name="System Italic" size="25.0" />
                           </font>
                        </Label>
                        <Slider fx:id="SFXSlider" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox layoutX="339.0" layoutY="286.0" prefHeight="200.0" prefWidth="154.0">
               <children>
                  <Label text="Account Management" />
                  <Button fx:id="DeleteAccountBtn" ellipsisString="" onAction="#deleteAccount" styleClass="back-button" text="Delete Account" />
                  <Button fx:id="ResetAccountBtn" ellipsisString="" onAction="#resetAccount" prefHeight="38.0" prefWidth="203.0" styleClass="back-button" text="Reset Account" />
               </children>
            </VBox>
            <Button fx:id="ExitBtn" ellipsisString="" layoutX="79.0" layoutY="386.0" onAction="#handleBack" styleClass="back-button" text="ESCI" />
            <VBox layoutX="502.0" layoutY="357.0">
               <children>
                  <Label text="Color Manager Theme" />
                  <ColorPicker fx:id="accentPrimary" onAction="#onPrimary" />
                  <ColorPicker fx:id="accentSecondary" onAction="#onSecondary" />
                  <ColorPicker fx:id="accentTernary" onAction="#onTernary" />
                  <Button fx:id="ImagePicker" mnemonicParsing="false" onAction="#onImagePick" prefHeight="38.0" prefWidth="149.0" text="Button" />
               </children>
            </VBox>
         </children>
      </Pane>
   </children>
</StackPane>
