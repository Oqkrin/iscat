<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@../styles/options-menu.css" xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="uni.gaben.iscat.iscat_screens.options.OptionsMenuController">
   <Pane fx:id="paneMaster" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
         prefHeight="509.0" prefWidth="889.0" styleClass="menu-background">
      <VBox alignment="TOP_CENTER" layoutX="305.0" layoutY="131.0" prefWidth="280.0" spacing="12.0"
            styleClass="option-card, audio-card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
         </padding>
         <Label styleClass="card-header" text="AUDIO"/>

         <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sub-control-box, accent-box-primary">
            <padding>
               <Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/>
            </padding>
            <Label fx:id="skinNameLabel2" minWidth="65.0" prefWidth="65.0" styleClass="control-label"
                   text="MASTER"/>
            <Slider fx:id="BGMSlider1" styleClass="modern-slider" HBox.hgrow="ALWAYS"/>
         </HBox>

         <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sub-control-box, accent-box-secondary">
            <padding>
               <Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/>
            </padding>
            <Label fx:id="skinNameLabel" minWidth="65.0" prefWidth="65.0" styleClass="control-label"
                   text="BGM"/>
            <Slider fx:id="BGMSlider" styleClass="modern-slider" HBox.hgrow="ALWAYS"/>
         </HBox>

         <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sub-control-box, accent-box-ternary">
            <padding>
               <Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/>
            </padding>
            <Label fx:id="skinNameLabel1" minWidth="65.0" prefWidth="65.0" styleClass="control-label"
                   text="SFX"/>
            <Slider fx:id="SFXSlider" styleClass="modern-slider" HBox.hgrow="ALWAYS"/>
         </HBox>
      </VBox>

      <VBox fx:id="mainOptions" layoutX="25.0" layoutY="37.0" prefWidth="280.0" spacing="12.0"
            styleClass="option-card, video-card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
         </padding>
         <Label styleClass="card-header" text="DISPLAY"/>

         <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="sub-control-box, accent-box-primary">
            <padding>
               <Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/>
            </padding>
            <Label fx:id="skinNameLabel11" minWidth="65.0" prefWidth="65.0" styleClass="control-label"
                   text="UI Scale"/>
            <Slider fx:id="scaleSlider" blockIncrement="2.0" max="96.0" min="1.0" onDragDetected="#updateScale"
                    value="64.0" HBox.hgrow="ALWAYS"/>
         </HBox>

         <CheckBox fx:id="checkFps" mnemonicParsing="false" onAction="#toggleFPSVisible"
                   styleClass="modern-checkbox" text="SHOW FPS OVERLAY"/>
         <CheckBox fx:id="FullscreenCheck" mnemonicParsing="false" onAction="#toggleFullscreen"
                   styleClass="modern-checkbox" text="FULLSCREEN MODE"/>
      </VBox>

      <VBox layoutX="60.0" layoutY="272.0" prefWidth="210.0" spacing="12.0" styleClass="option-card, theme-card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
         </padding>
         <Label styleClass="card-header" text="THEME"/>
         <VBox alignment="CENTER" spacing="8.0">
            <ColorPicker fx:id="accentPrimary" maxWidth="Infinity" onAction="#onPrimary"
                         promptText="Primary Accent"/>
            <ColorPicker fx:id="accentSecondary" maxWidth="Infinity" onAction="#onSecondary"
                         promptText="Secondary Accent"/>
            <ColorPicker fx:id="accentTernary" maxWidth="Infinity" onAction="#onTernary"
                         promptText="Ternary Accent"/>
            <ColorPicker fx:id="bgPrimary" maxWidth="Infinity" onAction="#onBgPrimary"
                         promptText="Background Color"/>
         </VBox>
         <Button fx:id="ImagePicker" ellipsisString="" maxWidth="Infinity" mnemonicParsing="false"
                 onAction="#onImagePick" styleClass="action-button" text="Get From Image"/>
      </VBox>

      <VBox alignment="TOP_CENTER" layoutX="550.0" layoutY="403.0" prefHeight="100.0" prefWidth="333.0"
            spacing="12.0" styleClass="option-card, danger-card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
         </padding>
         <Label alignment="TOP_CENTER" contentDisplay="CENTER" styleClass="card-header" text="ACCOUNT"/>
         <HBox spacing="16.0">
            <children>
               <Button fx:id="ResetAccountBtn" maxWidth="Infinity" onAction="#resetAccount"
                       styleClass="danger-button-weak" text="Reset Account"/>
               <Button fx:id="DeleteAccountBtn" maxWidth="Infinity" onAction="#deleteAccount"
                       style="-fx-text-fill: RED;" styleClass="danger-button-strong" text="Delete Account"/>
            </children>
         </HBox>
      </VBox>

      <VBox fx:id="controlsBox" alignment="TOP_CENTER" layoutX="577.0" layoutY="14.0" prefHeight="355.0"
            prefWidth="280.0" spacing="14.0" styleClass="option-card, controls-card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
         </padding>
         <Label styleClass="card-header" text="KEYBINDINGS"/>

         <VBox alignment="CENTER" spacing="4.0" styleClass="key-cluster">
            <Label styleClass="cluster-label" text="Movement"/>
            <Button fx:id="walkUp" mnemonicParsing="false" onAction="#changeControl" styleClass="key-cap"
                    text="W"/>
            <HBox alignment="CENTER" spacing="4.0">
               <Button fx:id="walkLeft" mnemonicParsing="false" onAction="#changeControl"
                       styleClass="key-cap" text="A"/>
               <Button fx:id="walkDown" mnemonicParsing="false" onAction="#changeControl"
                       styleClass="key-cap" text="S"/>
               <Button fx:id="walkRight" mnemonicParsing="false" onAction="#changeControl"
                       styleClass="key-cap" text="D"/>
            </HBox>
         </VBox>

         <VBox spacing="8.0" styleClass="action-rows">
            <HBox alignment="CENTER_LEFT" styleClass="binding-row">
               <Label maxWidth="Infinity" styleClass="binding-label" text="Dash Primary"
                      HBox.hgrow="ALWAYS"/>
               <Button fx:id="dash1" mnemonicParsing="false" onAction="#changeControl"
                       styleClass="key-cap-wide" text="Space"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" styleClass="binding-row">
               <Label maxWidth="Infinity" styleClass="binding-label" text="Dash Secondary"
                      HBox.hgrow="ALWAYS"/>
               <Button fx:id="dash2" mnemonicParsing="false" onAction="#changeControl"
                       styleClass="key-cap-wide" text="Middle Mouse"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" styleClass="binding-row">
               <Label maxWidth="Infinity" styleClass="binding-label" text="Combat Attack"
                      HBox.hgrow="ALWAYS"/>
               <Button fx:id="esc" mnemonicParsing="false" onAction="#changeControl"
                       styleClass="key-cap-wide" text="Left Click"/>
            </HBox>
         </VBox>

         <Pane VBox.vgrow="ALWAYS"/>
         <Button fx:id="resetControlsBtn" maxWidth="Infinity" mnemonicParsing="false" onAction="#resetControls"
                 styleClass="action-button-weak" text="RESTORE DEFAULTS"/>
      </VBox>

      <Button fx:id="ExitBtn" layoutX="385.0" layoutY="433.0" onAction="#handleBack" prefHeight="40.0"
              prefWidth="120.0" styleClass="back-button" text="Main Menu"/>

   </Pane>
</StackPane>