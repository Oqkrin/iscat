                     <children>
                        <Label text="Main Movements" />
                        <Button fx:id="walkUp" mnemonicParsing="false" onAction="#changeControl" text="W" />
                        <HBox alignment="TOP_CENTER" prefHeight="42.0" prefWidth="328.0">
                           <children>
                              <Button fx:id="walkLeft" mnemonicParsing="false" onAction="#changeControl" text="A" />
                              <Button fx:id="walkDown" mnemonicParsing="false" onAction="#changeControl" text="S" />
                              <Button fx:id="walkRight" mnemonicParsing="false" onAction="#changeControl" text="D" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <HBox alignment="CENTER" prefHeight="49.0" prefWidth="328.0">
                     <children>
                        <Label text="Dash 1" />
                        <Button fx:id="dash1" mnemonicParsing="false" onAction="#changeControl" prefHeight="38.0" prefWidth="130.0" text="Space" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="42.0" prefWidth="328.0">
                     <children>
                        <Label text="Dash 2" />
                        <Button fx:id="dash2" mnemonicParsing="false" onAction="#changeControl" text="Middle mouse" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="52.0" prefWidth="328.0">
                     <children>
                        <Label text="Attack" />
