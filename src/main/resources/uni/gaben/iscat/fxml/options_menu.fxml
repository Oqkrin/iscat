                  <HBox alignment="CENTER" prefHeight="39.0" prefWidth="158.0" spacing="8.0">
                     <children>
                        <Label fx:id="skinNameLabel2" ellipsisString="" text="MASTER AUDIO" textFill="#00ffcc">
